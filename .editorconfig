root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
# --- File-scoped namespaces (IDE0161) ---
csharp_style_namespace_declarations = file_scoped:error

# --- var preference (maps to IDE0007 / IDE0008) ---
csharp_style_var_for_built_in_types = true:error
csharp_style_var_when_type_is_apparent = true:error
csharp_style_var_elsewhere = true:error

# --- File size (SonarAnalyzer S104: max 200 lines) ---
dotnet_diagnostic.S104.severity = error

# --- Method size (SonarAnalyzer S138: max 30 lines) ---
dotnet_diagnostic.S138.severity = error

# --- Silence unrelated Sonar rules that fire on auto-generated/scaffold code ---
dotnet_diagnostic.S1135.severity = suggestion   # TODO comments → suggestion only

[*.{csproj,props,targets,slnx}]
indent_size = 2
